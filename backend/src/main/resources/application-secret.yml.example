# 复制此文件为 application-secret.yml 并填入实际值
# Copy this file to application-secret.yml and fill in actual values

spring:
  datasource:
    username: root
    password: your_db_password

jwt:
  secret: your_jwt_secret_base64_encoded

minio:
  endpoint: http://your-minio-host:9000
  access-key: your_minio_access_key
  secret-key: your_minio_secret_key

ai:
  mimo:
    api-key: your_mimo_api_key
